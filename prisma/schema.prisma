// CoreLink — Prisma schema
// Fase 1: solo fundación (datasource + generator). Sin modelos de dominio.
// Los modelos (User, Post, etc.) se añaden en Fase 3.
//
// Nota Prisma 7: la connection URL ya no vive aquí. Se configura en
// `prisma.config.ts` (raíz) vía env("DATABASE_URL"). Ver https://pris.ly/prisma7-client-config

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id
  name          String
  email         String
  emailVerified Boolean      @default(false)
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  isAnonymous   Boolean?     @default(false)
  // Plugin admin (Fase 6a): rol de plataforma + estado de baneo.
  // role: "user" (default) | "moderator" | "admin".
  role          String?      @default("user")
  banned        Boolean?     @default(false)
  banReason     String?
  banExpires    DateTime?
  sessions      Session[]
  accounts      Account[]
  members       Member[]
  invitations   Invitation[]

  // Relaciones inversas de dominio (Fase 3)
  profile               Profile?
  posts                 Post[]
  reactions             Reaction[]
  followers             Follow[]       @relation("following")
  following             Follow[]       @relation("follower")
  mentions              Mention[]
  notifications         Notification[] @relation("notificationRecipient")
  notificationsAsActor  Notification[] @relation("notificationActor")

  // Relaciones inversas de mensajería (Fase 8a)
  conversationsCreated  Conversation[]       @relation("conversationCreator")
  conversationMembers   ConversationMember[]
  messagesSent          Message[]

  @@unique([email])
  @@map("user")
}

model Session {
  id                   String   @id
  expiresAt            DateTime
  token                String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  ipAddress            String?
  userAgent            String?
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganizationId String?
  // Plugin admin (Fase 6a): id del admin que está impersonando esta sesión.
  impersonatedBy       String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Organization {
  id          String       @id
  name        String
  slug        String
  logo        String?
  createdAt   DateTime
  metadata    String?
  members     Member[]
  invitations Invitation[]

  @@unique([slug])
  @@map("organization")
}

model Member {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String       @default("member")
  createdAt      DateTime

  @@index([organizationId])
  @@index([userId])
  @@map("member")
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

// ─────────────────────────────────────────────────────────────────────────────
// Dominio CoreLink (Fase 3)
// Modelos de la red social interna. Se relacionan con el `User` de Better Auth
// por su id. onDelete: Cascade aplicado para arrastrar contenido dependiente.
// ─────────────────────────────────────────────────────────────────────────────

enum ChannelType {
  DEPARTMENT
  TOPIC
}

enum ReactionType {
  LIKE
  CELEBRATE
  INSIGHTFUL
  SUPPORT
}

enum NotificationType {
  REPLY
  MENTION
  REACTION
  FOLLOW
  OFFICIAL_POST
}

// Mensajería (Fase 8a).
enum ConversationType {
  DIRECT
  GROUP
}

// Rol dentro de una conversación de grupo. ADMIN = creador/administrador del
// grupo (puede renombrar/gestionar miembros en fases futuras). En DM ambos son
// MEMBER. No confundir con el `User.role` de plataforma (admin/moderator/user).
enum MemberRole {
  MEMBER
  ADMIN
}

// Perfil 1:1 con User. departmentId apunta a un Channel de tipo DEPARTMENT.
model Profile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName  String
  bio          String?
  avatarUrl    String?
  jobTitle     String?
  departmentId String?
  department   Channel? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([departmentId])
  @@map("profile")
}

// Canales por departamento o tema.
model Channel {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  type        ChannelType @default(TOPIC)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  posts       Post[]
  profiles    Profile[]

  @@map("channel")
}

// Posts del feed. Soporta hilos anidados vía parentId (autorreferencia).
model Post {
  id         String    @id @default(cuid())
  authorId   String
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  channelId  String?
  channel    Channel?  @relation(fields: [channelId], references: [id], onDelete: SetNull)
  parentId   String?
  parent     Post?     @relation("PostThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies    Post[]    @relation("PostThread")
  content    String
  isOfficial Boolean   @default(false)
  createdAt  DateTime  @default(now())
  editedAt   DateTime?

  reactions     Reaction[]
  attachments   Attachment[]
  mentions      Mention[]
  notifications Notification[]

  @@index([authorId])
  @@index([channelId])
  @@index([parentId])
  @@map("post")
}

// Reacciones tipadas. Un usuario puede dar varios tipos a un post, no duplicar.
model Reaction {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String
  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  type      ReactionType
  createdAt DateTime     @default(now())

  @@unique([userId, postId, type])
  @@index([postId])
  @@index([userId])
  @@map("reaction")
}

// Adjunto POLIMÓRFICO (Fase 9a): pertenece a EXACTAMENTE uno de un Post o un
// Message (no ambos, no ninguno). La exclusividad la garantiza un CHECK
// constraint en SQL (ver migración `attachment_message`): Prisma no modela
// CHECKs, pero la columna `key` y las dos FKs opcionales sí están aquí.
//
//   - `key`   : clave interna en el storage (para borrar el objeto del backend).
//               La provee el StorageDriver al subir.
//   - `width`/`height`: dimensiones de imagen si se conocen (opcional; null en
//               PDFs o si no se calcularon). La UI (9b) las usa para reservar
//               espacio y evitar saltos de layout.
model Attachment {
  id        String   @id @default(cuid())
  postId    String?
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  messageId String?
  message   Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)
  url       String
  key       String
  mime      String
  size      Int
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([messageId])
  @@map("attachment")
}

// Seguimiento entre usuarios para el feed personalizado.
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follow")
}

// Menciones de usuarios en un post.
model Mention {
  id              String   @id @default(cuid())
  postId          String
  post            Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  mentionedUserId String
  mentionedUser   User     @relation(fields: [mentionedUserId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())

  @@unique([postId, mentionedUserId])
  @@index([mentionedUserId])
  @@map("mention")
}

// Notificaciones al destinatario, provocadas por un actor.
model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation("notificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actorId   String
  actor     User             @relation("notificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  type      NotificationType
  postId    String?
  post      Post?            @relation(fields: [postId], references: [id], onDelete: Cascade)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([actorId])
  @@index([postId])
  @@map("notification")
}

// ─────────────────────────────────────────────────────────────────────────────
// Mensajería / Chat (Fase 8a)
// Conversaciones DIRECT (1:1) y GROUP, mensajes, membresías con no-leídos.
// El tiempo real (mensaje nuevo, "escribiendo", leído) viaja por el bus SSE
// existente (src/server/events) ampliando la unión AppEvent; NO crea filas
// Notification (el chat tiene su propio no-leído vía lastReadAt).
// ─────────────────────────────────────────────────────────────────────────────

// Conversación: hilo de mensajes entre 2 (DIRECT) o N (GROUP) usuarios.
// `updatedAt` se toca al enviar un mensaje para ordenar por actividad reciente.
//
// Unicidad de DM 1:1: `directKey` es una clave determinista del par ordenado
// (`userIdMenor:userIdMayor`) para las conversaciones DIRECT y `null` para las
// GROUP. Al ser @unique, garantiza atomicidad y ausencia de carreras en
// `getOrCreateDirectConversation` (un único par no puede duplicarse). Postgres
// permite múltiples NULL en una columna unique, así que los grupos no chocan.
model Conversation {
  id          String           @id @default(cuid())
  type        ConversationType
  /// Nombre del grupo (solo GROUP; null en DM).
  name        String?
  /// Clave determinista del par para DM (orden estable); null en GROUP.
  directKey   String?          @unique
  createdById String
  createdBy   User             @relation("conversationCreator", fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  members  ConversationMember[]
  messages Message[]

  @@index([createdById])
  @@map("conversation")
}

// Membresía de un usuario en una conversación. `lastReadAt` marca hasta dónde
// ha leído (para contar no-leídos y emitir confirmaciones de leído).
model ConversationMember {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           MemberRole   @default(MEMBER)
  joinedAt       DateTime     @default(now())
  /// Última lectura del miembro; null = nunca leyó (todo es no-leído).
  lastReadAt     DateTime?

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
  @@map("conversation_member")
}

// Mensaje de una conversación. `editedAt` para ediciones futuras.
model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content        String
  createdAt      DateTime     @default(now())
  editedAt       DateTime?

  // Adjuntos del mensaje (Fase 9a). Cascade al borrar el mensaje.
  attachments    Attachment[]

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("message")
}
