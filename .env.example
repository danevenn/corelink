# CoreLink — variables de entorno (plantilla versionada)
# Copia este archivo a `.env` y ajusta los valores para tu entorno local.

# Postgres local (docker-compose.yml). user=corelink pass=corelink db=corelink
DATABASE_URL="postgresql://corelink:corelink@localhost:5432/corelink?schema=public"

# Better Auth (Fase 2)
# Genera un secreto aleatorio: `openssl rand -base64 32`
BETTER_AUTH_SECRET="genera-un-secreto-aleatorio-aqui"
BETTER_AUTH_URL="http://localhost:3000"

# Almacenamiento de archivos (Fase 9a)
# Driver de almacenamiento: "local" (filesystem .uploads/, default en dev) o
# "vercel-blob" (CDN de Vercel Blob, para producción).
STORAGE_DRIVER=local
# Token de Vercel Blob. Sólo en producción/deploy: lo provee la integración de
# Vercel. Si está presente y STORAGE_DRIVER no es "local", se usa Vercel Blob.
# En local NO se usa (déjalo vacío y mantén STORAGE_DRIVER=local).
# BLOB_READ_WRITE_TOKEN=""

# Acceso demo para portfolio (R1).
# Si "true": la landing y el login muestran un botón "Probar demo" que inicia
# sesión con una cuenta demo REAL sembrada (lucia.martin@corelink.demo, rol user)
# mediante la Server Action `demoLogin`. La action revalida esta variable en
# servidor. En el producto real, déjala sin definir o en "false" — no existirá
# el acceso demo. Es `NEXT_PUBLIC_` para que el cliente decida si pinta el botón.
NEXT_PUBLIC_DEMO_MODE=false

# ─────────────────────────────────────────────────────────────────────────────
# TESTS (Vitest) — copia estas claves a un archivo `.env.test` (gitignored).
# ─────────────────────────────────────────────────────────────────────────────
# Los tests de integración corren contra una BD de Postgres SEPARADA de la de
# desarrollo (truncan tablas entre tests). Crea la BD una vez:
#   docker exec corelink-postgres psql -U corelink -c "CREATE DATABASE corelink_test"
# y aplica las migraciones:
#   DATABASE_URL=...corelink_test pnpm prisma migrate deploy
#
# Contenido recomendado de `.env.test`:
#   DATABASE_URL="postgresql://corelink:corelink@localhost:5432/corelink_test?schema=public"
#   BETTER_AUTH_SECRET="test-secret-do-not-use-in-prod-0000000000000000000="
#   BETTER_AUTH_URL="http://localhost:3000"
#   STORAGE_DRIVER=local
#   NEXT_PUBLIC_DEMO_MODE=false
#
# En CI (GitHub Actions) estas variables se inyectan desde el job (ver
# .github/workflows/ci.yml), no desde `.env.test`.
